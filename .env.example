# =============================================================================
# Environment Variables Template for ExploresSG Auth Service
# =============================================================================
# 
# INSTRUCTIONS:
# 1. Copy this file to .env (DO NOT commit .env to Git)
# 2. Replace the placeholder values with your actual credentials
# 3. Source the .env file before running the application
#
# =============================================================================

# =============================================================================
# GOOGLE OAUTH2 CONFIGURATION
# =============================================================================
# Get these from Google Cloud Console > APIs & Services > Credentials
# https://console.cloud.google.com/apis/credentials

# Google OAuth2 Client ID (Public - safe to expose in frontend)
GOOGLE_CLIENT_ID=your-google-client-id-here.apps.googleusercontent.com

# Google OAuth2 Client Secret (PRIVATE - never expose publicly)
GOOGLE_CLIENT_SECRET=GOCSPX-your-google-client-secret-here

# =============================================================================
# JWT CONFIGURATION  
# =============================================================================
# JWT Secret Key for token signing (generate a secure random key)
JWT_SECRET=your-super-secret-jwt-signing-key-at-least-32-characters-long

# JWT Token Expiration Times (in milliseconds)
JWT_EXPIRATION=86400000        # 24 hours
JWT_REFRESH_EXPIRATION=604800000   # 7 days

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================
# Frontend application URL for redirects
FRONTEND_URL=http://localhost:3000

# Database Configuration (Production)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=exploresg_auth
DB_USERNAME=exploresg_user
DB_PASSWORD=exploresg_password

# Application Port
SERVER_PORT=8080

# Active Spring Profile (dev, prod, test)
SPRING_PROFILES_ACTIVE=dev